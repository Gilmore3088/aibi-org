# .env.local.example
#
# Documents every environment variable the codebase reads. Copy to
# `.env.local` and fill in real values for local development. Never
# commit `.env.local` itself.
#
# Vercel production / preview / staging values live in the Vercel
# dashboard (Project Settings → Environment Variables). This file
# documents what to set there as well — the variable names match.
#
# Legend:
#   [REQUIRED]    feature breaks without it
#   [OPTIONAL]    feature degrades gracefully without it
#   [DEV-ONLY]    set in .env.local for local dev; never in production
#   [STAGING]     set on Vercel preview/staging only; never in production
#
# Last audited: 2026-05-05 (post-merge of Specs 1-4).

# ──────────────────────────────────────────────────────────────────────
# CORE INFRASTRUCTURE
# ──────────────────────────────────────────────────────────────────────

# [REQUIRED] Supabase — postgres + auth + storage. Used everywhere.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# [OPTIONAL] Used by absolute-URL builders. Defaults to inferred origin.
NEXT_PUBLIC_SITE_URL=https://aibankinginstitute.com

# Vercel injects VERCEL=1 and VERCEL_ENV=production|preview|development
# automatically — do not set manually. Read by next.config.mjs guards.

# ──────────────────────────────────────────────────────────────────────
# SPEC 2 — PDF DOWNLOAD
# ──────────────────────────────────────────────────────────────────────

# [REQUIRED in production] Bearer token Vercel Cron sends to nightly
# cleanup. Without it, /api/assessment/pdf/cron-cleanup returns 401
# every night and 30+ day old PDFs accumulate.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# [STAGING] Suppresses Puppeteer-driven PDF generation on staging only.
SKIP_PDF_GENERATION=

# [DEV-ONLY] Bypasses CRON_SECRET check on the cleanup endpoint.
SKIP_CRON_AUTH=

# [DEV-ONLY] Override Chrome path if not at the default Mac location.
PUPPETEER_LOCAL_CHROME=

# ──────────────────────────────────────────────────────────────────────
# SPEC 3 — CONVERTKIT TIER SEQUENCES
# ──────────────────────────────────────────────────────────────────────

# [REQUIRED for CK tagging] ConvertKit v3 API Key. Without it,
# tagAssessmentTier returns skipped, no tagging, no Plausible event.
CONVERTKIT_API_KEY=

# [REQUIRED for retake re-routing] ConvertKit v3 API Secret —
# different credential from API Key. Required by /tags/:id/unsubscribe.
# Without it, retakes silently keep the old tier tag.
CONVERTKIT_API_SECRET=

# [REQUIRED] Numeric tag IDs from the four CK Tags created in dashboard.
# Find IDs in the URL: app.convertkit.com/tags/{id}
CONVERTKIT_TAG_ID_STARTING_POINT=
CONVERTKIT_TAG_ID_EARLY_STAGE=
CONVERTKIT_TAG_ID_BUILDING_MOMENTUM=
CONVERTKIT_TAG_ID_READY_TO_SCALE=

# [STAGING] Suppresses all ConvertKit calls on staging. The
# next.config.mjs guard throws at build if set when VERCEL_ENV=production.
SKIP_CONVERTKIT=

# ──────────────────────────────────────────────────────────────────────
# EMAIL — RESEND (transactional)
# ──────────────────────────────────────────────────────────────────────

# [REQUIRED for breakdown email] Without it, post-capture readiness
# breakdown email is skipped (best-effort).
RESEND_API_KEY=

# [OPTIONAL] From address + name. Defaults to Resend dashboard config.
RESEND_FROM=onboarding@resend.dev
RESEND_FROM_NAME=The AI Banking Institute

# [DEV-ONLY] Bypass Resend without an API key.
SKIP_RESEND=

# ──────────────────────────────────────────────────────────────────────
# CRM — HUBSPOT
# ──────────────────────────────────────────────────────────────────────

# [REQUIRED in production] HubSpot Private App access token. Without it,
# capture-email's HubSpot upsert is skipped (logged warn). Custom
# properties must be pre-created per CLAUDE.md:
#   assessment_score, score_tier, institution_name, asset_size, lead_source
HUBSPOT_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# PAYMENTS — STRIPE (Phase 2)
# ──────────────────────────────────────────────────────────────────────

# [REQUIRED for Phase 2] Stripe secret + webhook signing secret.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_KEY=

# Price IDs created via Stripe MCP (test-mode sandbox account
# acct_1TTll2Ry9NIFjtII). For live launch, recreate the same products in
# the live account and substitute the live price IDs.
#
# AiBI-Practitioner ($295 individual / $199 institution-bulk 10+ seats)
STRIPE_AIBIP_PRICE_ID=
STRIPE_AIBIP_INSTITUTION_PRICE_ID=

# In-Depth AI Readiness Assessment ($99 individual; institution mode
# deferred — bulk orders go through hello@aibankinginstitute.com)
STRIPE_INDEPTH_PRICE_ID=
STRIPE_INDEPTH_INSTITUTION_PRICE_ID=

# ──────────────────────────────────────────────────────────────────────
# ANALYTICS — PLAUSIBLE
# ──────────────────────────────────────────────────────────────────────

# [REQUIRED] Domain registered in Plausible. Without it, custom events
# fire client-side but aren't associated to a site.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=aibankinginstitute.com

# ──────────────────────────────────────────────────────────────────────
# SCHEDULING — CALENDLY
# ──────────────────────────────────────────────────────────────────────

# [REQUIRED for "Book a briefing" CTAs] Calendly link.
NEXT_PUBLIC_CALENDLY_URL=

# ──────────────────────────────────────────────────────────────────────
# AI PROVIDERS
# ──────────────────────────────────────────────────────────────────────

# [REQUIRED if AI features used] Per CLAUDE.md auto-memory:
# ANTHROPIC_API_KEY is set in shell env (~/.zshrc) for local dev,
# not .env.local. For Vercel: set in dashboard.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# MISC
# ──────────────────────────────────────────────────────────────────────

# [OPTIONAL] Comma-separated emails for review notifications.
REVIEWER_EMAILS=

# [REQUIRED in production] Toolbox per-IP rate limit (Plan E). 32-byte
# hex string. Required in production so IP hashes are stable across
# pod restarts. In dev, omit to use a session-local random value.
# Generate with: openssl rand -hex 32
TOOLBOX_IP_HASH_SALT=

# [OPTIONAL] Set to 'true' to flip the site into coming-soon mode.
COMING_SOON=

# [DEV-ONLY] Bypass Supabase user_profiles writes in dev.
SKIP_SUPABASE_PROFILES=

# [DEV-ONLY] Bypass enrollment gate.
SKIP_ENROLLMENT_GATE=
